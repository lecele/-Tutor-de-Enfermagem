# ============================================================
# Variáveis necessárias para rodar o Tutor de Enfermagem
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# --- API URL ---
# Use /api para Next.js API Routes (Vercel)
# Use http://localhost:8000 para backend Python local
NEXT_PUBLIC_API_URL=/api

# --- Google AI (obrigatório) ---
GOOGLE_API_KEY=sua_chave_aqui

# --- Supabase (obrigatório) ---
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_service_role_key_aqui

# --- RAG (opcional, usa defaults se não definido) ---
RAG_MATCH_THRESHOLD=0.45
RAG_MATCH_COUNT=5
